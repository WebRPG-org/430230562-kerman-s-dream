00,"pan":0}]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["“咚——咚——咚——”"]},{"code":249,"indent":2,"parameters":[{"name":"se_heartbeat","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["这个声音太大了。那不再是隔着皮肤听到的心跳，"]},{"code":401,"indent":2,"parameters":["而像是你就坐在一口被狠狠敲击的大钟里面。"]},{"code":401,"indent":2,"parameters":[""]},{"code":401,"indent":2,"parameters":[""]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["莉卵每一次心脏的搏动，这片空间里的羊红色液体就会"]},{"code":401,"indent":2,"parameters":["微微震颤一下，带着你小小的身体一起共振。"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["你的鼻子，只能吸入那种浓稠的、混合着甜腥味的气溶胶。"]},{"code":401,"indent":2,"parameters":["那种味道很复杂，有类似熟透水蜜桃般的甜香，"]},{"code":401,"indent":2,"parameters":["又混杂着海水的咸腥，甚至还有一丝荷花般的蜜香味。"]},{"code":401,"indent":2,"parameters":[""]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["每一次小心翼翼的呼吸，都像是把这种味道直接吞进了肺里，"]},{"code":401,"indent":2,"parameters":["让你的理智越发昏沉。"]},{"code":401,"indent":2,"parameters":["包裹着你的，只有那像是有自我意识一般的、层层叠叠的软肉。"]},{"code":401,"indent":2,"parameters":[""]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["颤抖的你蜷缩着膝盖，脊背紧紧贴着一面弧形的肉壁，"]},{"code":401,"indent":2,"parameters":["那并不是静止的墙壁，它在轻微地颤动，"]},{"code":401,"indent":2,"parameters":["伴随着上方那些重型脏器的运作，"]},{"code":401,"indent":2,"parameters":["不断把一股股温暖的波浪传导给你。"]},{"code":101,"indent":2,"parameters":["Actor1",0,0,2]},{"code":401,"indent":2,"parameters":["呜呜~~~，莉卵妹妹的下体，好香，好香......"]},{"code":101,"indent":2,"parameters":["莉莉艾",0,0,2]},{"code":401,"indent":2,"parameters":["肯定香啊,这可是我长年累月用草药调养的身体呢，"]},{"code":401,"indent":2,"parameters":["专门让你们这些小人感到快感的呀！"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["你感觉她的话里似乎隐藏了什么不可告人的秘密..."]},{"code":401,"indent":2,"parameters":["不过是什么呢?"]},{"code":0,"indent":2,"parameters":[]},{"code":412,"indent":1,"parameters":[]},{"code":111,"indent":1,"parameters":[1,12,0,60,1]},{"code":0,"indent":2,"parameters":[]},{"code":411,"indent":1,"parameters":[]},{"code":111,"indent":2,"parameters":[0,4,0]},{"code":121,"indent":3,"parameters":[4,4,1]},{"code":101,"indent":3,"parameters":["",0,0,2]},{"code":401,"indent":3,"parameters":["理智这种东西，在这里就像是被扔进开水里的方糖，"]},{"code":401,"indent":3,"parameters":["正在迅速地崩解、融化。"]},{"code":101,"indent":3,"parameters":["",0,0,2]},{"code":401,"indent":3,"parameters":["你试图想起自己刚才为什么要挣扎,甚至试图想起外面的世界。"]},{"code":401,"indent":3,"parameters":["但是,只要你哪怕动那么一下脑筋，"]},{"code":401,"indent":3,"parameters":["周围那些不知疲倦的肉壁就会更热情地挤压过来。"]},{"code":249,"indent":3,"parameters":[{"name":"se_heartbeat","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":3,"parameters":["",0,0,2]},{"code":401,"indent":3,"parameters":["“咚--咚——咚—”"]},{"code":249,"indent":3,"parameters":[{"name":"se_heartbeat","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":3,"parameters":["",0,0,2]},{"code":401,"indent":3,"parameters":["那声音变得更沉重了，而且节奏似乎变得有点不一样。"]},{"code":401,"indent":3,"parameters":["不……那是莉卵的心跳声和你自己的心跳声混在了一起。"]},{"code":401,"indent":3,"parameters":["这里太热了，缺氧的感觉让你开始耳鸣，"]},{"code":401,"indent":3,"parameters":["那种持续不断的高温蒸汽把你的意识蒸得软趴趴的。"]},{"code":249,"indent":3,"parameters":[{"name":"se_squishy4","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":3,"parameters":["",0,0,2]},{"code":401,"indent":3,"parameters":["滋……滋溜……"]},{"code":101,"indent":3,"parameters":["",0,0,2]},{"code":401,"indent":3,"parameters":["你感觉到有什么东西改变了。"]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":[""]},{"code":401,"indent":3,"parameters":[""]},{"code":101,"indent":3,"parameters":["",0,0,2]},{"code":401,"indent":3,"parameters":["你头顶那个一直紧紧闭着的硬环——那个名为子宫颈口的肉圈，"]},{"code":401,"indent":3,"parameters":["就像是一个终于被舔化了的甜甜圈，"]},{"code":401,"indent":3,"parameters":["原本那种带着韧性的紧绷感正在迅速消失"]},{"code":236,"indent":3,"parameters":["rain",9,30,false]},{"code":121,"indent":3,"param